{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/energy-anomaly-detector/browser",
  "installCommand": "npm install",
  "framework": "angular",
  "env": {
    "VERCEL_API_URL": {
      "description": "Backend API URL (Render deployment)",
      "value": "https://energy-anomaly-detector-api.onrender.com"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
