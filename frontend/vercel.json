{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/energy-anomaly-detector/browser",
  "installCommand": "npm install",
  "framework": "angular",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}